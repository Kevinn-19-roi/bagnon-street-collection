# ============================================================
# BAGNON STREET COLLECTION — Environment Variables
# ============================================================

# ─── SUPABASE ───────────────────────────────────────────────
# Found in: supabase.com → Project Settings → API

# Public URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public Anon Key (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (⚠️ NEVER expose — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── NEXT.JS ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bagnon-street-collection-ci.vercel.app

